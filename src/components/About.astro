---
/* 4.4 Apie mus — dviejų stulpelių blokas: Manto nuotrauka + tekstas.
   Nuotrauka („main photo") svarbi — parodo žmogų, kuris dirba (pasitikėjimas). */
import { apie } from '@data/turinys.js';
import { site } from '@data/site.js';
import Icon from './Icon.astro';
---
<section class="about section section--cream" id="apie" aria-label="Apie ArbCut">
  <div class="container about__grid">
    <div class="about__media js-reveal-scroll">
      <img src="/assets/images/mantas-darbe.jpg" alt="Arboristas Mantas Gerulis dirba aukštyje" class="about__photo grain-photo" loading="lazy" width="640" height="800" />
      <div class="about__badge">
        <span class="about__badge-name">{site.savininkas}</span>
        <span class="about__badge-role">Arboristas aukštalipys · ArbCut</span>
      </div>
    </div>

    <div class="about__content js-reveal-scroll">
      <span class="eyebrow">{apie.eyebrow}</span>
      <h2 class="about__title section-title">{apie.antraste}</h2>
      <p class="about__body">{apie.lead}</p>
      <p class="about__body about__body--detail">{apie.detail}</p>

      <div class="about__points">
        <span class="about__point"><Icon name="zvaigzde" size={18} /> 5,0 ★ · 106 atsiliepimai</span>
        <span class="about__point"><Icon name="laikrodis" size={18} /> 13+ metų patirtis</span>
        <span class="about__point"><Icon name="autobokstelis" size={18} /> Nuosavas autobokštelis (20 m)</span>
      </div>

      <div class="about__ctas">
        <a href={site.telefonasHref} class="btn btn--call"><Icon name="telefonas" size={18} stroke={2.5} /> {site.telefonas}</a>
        <a href="#paslaugos" class="btn btn--outline">Žiūrėti paslaugas</a>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: var(--space-8); align-items: center; }

  .about__media { position: relative; }
  .about__photo { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: var(--radius); border: 3px solid var(--color-bg-card); box-shadow: 14px 14px 0 -2px rgba(219,122,34,0.22), var(--shadow-heavy); }
  .about__badge { position: absolute; left: 18px; bottom: 18px; background: var(--color-forest-deep); color: var(--color-text-light); padding: 12px 18px; border-radius: var(--radius); box-shadow: var(--shadow-card); border-left: 3px solid var(--color-rust); }
  .about__badge-name { display: block; font-family: var(--font-display); font-size: 1.25rem; text-transform: uppercase; letter-spacing: 0.02em; }
  .about__badge-role { display: block; font-size: 0.8rem; opacity: 0.82; }

  .about__title { margin-bottom: var(--space-5); }
  .about__body { margin-bottom: var(--space-4); }
  .about__body--detail { font-size: 0.96rem; color: var(--color-text-muted); margin-bottom: var(--space-5); }

  .about__points { display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-5); margin-bottom: var(--space-6); }
  .about__point { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; color: var(--color-forest); font-size: 0.95rem; }
  .about__point svg { color: var(--color-rust); flex: 0 0 auto; }

  .about__ctas { display: flex; gap: var(--space-4); flex-wrap: wrap; }

  @media (max-width: 900px) {
    .about__grid { grid-template-columns: 1fr; gap: var(--space-6); }
    /* Visa nuotrauka matoma ir telpa mažame telefone — natūralus santykis, be apkirpimo */
    .about__media { max-width: 100%; margin-inline: auto; }
    .about__photo { aspect-ratio: auto; height: auto; max-height: 78vh; width: 100%; object-fit: contain; box-shadow: 10px 10px 0 -2px rgba(219,122,34,0.22), var(--shadow-card); }
    .about__badge { left: 10px; bottom: 10px; padding: 8px 12px; }
    .about__badge-name { font-size: 1rem; }
  }
  @media (max-width: 480px) { .about__ctas .btn { width: 100%; } }
</style>
