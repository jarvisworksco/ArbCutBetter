---
/* 4.7 Kodėl ArbCut — tamsi sekcija, 4 pasitikėjimo taškai. */
import { kodel } from '@data/turinys.js';
import Icon from './Icon.astro';
---
<section class="why section section--dark" id="kodel" aria-label="Kodėl ArbCut">
  <div class="container">
    <div class="section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center eyebrow--light">MŪSŲ PRIVALUMAI</span>
      <h2 class="section-title section-title--light">Kodėl ArbCut?</h2>
    </div>

    <div class="why__grid">
      {kodel.map((k, i) => (
        <div class="why-card js-reveal-scroll" style={`--reveal-delay:${i * 100}ms`}>
          <span class="why-card__icon"><Icon name={k.ikona} size={30} /></span>
          <h3 class="why-card__title">{k.antraste}</h3>
          <p class="why-card__desc">{k.tekstas}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .why-card { text-align: center; }
  .why-card__icon { width: 64px; height: 64px; margin: 0 auto var(--space-4); border-radius: 50%; display: grid; place-items: center; background: rgba(184,91,50,0.15); color: var(--color-rust); }
  .why-card__title { color: var(--color-text-light); font-size: 1.35rem; margin-bottom: 8px; }
  .why-card__desc { color: var(--color-text-light); opacity: 0.8; font-size: 0.95rem; }
  @media (max-width: 860px) { .why__grid { grid-template-columns: 1fr 1fr; gap: var(--space-7) var(--space-5); } }
  @media (max-width: 460px) { .why__grid { grid-template-columns: 1fr; } }
</style>
