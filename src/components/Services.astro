---
/* Paslaugos — 6 kategorijų kortelės (nuotrauka + numeris + sąrašas + 2 mygtukai).
   Tos pačios 12 realių paslaugų sugrupuotos. Kortelė veda į paslaugos puslapį. */
import { kategorijos } from '@data/paslaugos.js';
import Icon from './Icon.astro';
---
<section class="services section section--cream" id="paslaugos" aria-label="Paslaugos">
  <div class="container">
    <div class="section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center">PASLAUGOS</span>
      <h2 class="section-title">Visi medžių darbai — <span class="services__accent">vienoje vietoje</span></h2>
      <p>Nuo pavojingų medžių šalinimo iki aukštuminių darbų su autobokšteliu. Pasirinkite kategoriją arba tiesiog palikite užklausą.</p>
    </div>

    <div class="services__grid">
      {kategorijos.map((k) => (
        <article class="cat-card js-reveal-scroll">
          <a class="cat-card__media" href={k.nuoroda} aria-label={k.pavadinimas} style={`background-image:url('${k.nuotrauka}')`}>
            <span class="cat-card__badge">{k.nr} / Kategorija</span>
          </a>
          <div class="cat-card__body">
            <h3 class="cat-card__title">
              <span class="cat-card__title-icon"><Icon name={k.ikona} size={22} /></span>
              {k.pavadinimas}
            </h3>
            <ul class="cat-card__list" role="list">
              {k.punktai.map((p) => (
                <li><Icon name="atsakingai" size={18} stroke={2.5} class="cat-card__check" /> <span>{p}</span></li>
              ))}
            </ul>
            <div class="cat-card__actions">
              <button type="button" class="btn btn--call cat-card__cta" data-modal-trigger aria-haspopup="dialog">
                Užsakyti paslaugą <Icon name="rodykle" size={16} stroke={2.5} />
              </button>
              <a href={k.nuoroda} class="btn btn--outline cat-card__more">
                <Icon name="ivertinimas" size={16} stroke={2} /> Skaityti plačiau
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services__accent { color: var(--color-rust); }
  .services__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); margin-top: var(--space-7); }

  .cat-card { display: flex; flex-direction: column; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-card); transition: transform var(--t-base), box-shadow var(--t-base), border-color var(--t-base); }
  .cat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-heavy); border-color: var(--color-rust); }

  .cat-card__media { position: relative; display: block; height: 200px; background-size: cover; background-position: center; }
  .cat-card__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(14,26,20,0.55), rgba(14,26,20,0.05) 60%); transition: background var(--t-base); }
  .cat-card:hover .cat-card__media::after { background: linear-gradient(to top, rgba(14,26,20,0.65), rgba(14,26,20,0.1) 60%); }
  .cat-card:hover .cat-card__media { transform: none; }
  .cat-card__badge { position: absolute; z-index: 1; left: 14px; bottom: 14px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-light); background: rgba(219,122,34,0.92); padding: 5px 12px; border-radius: 6px; }

  .cat-card__body { display: flex; flex-direction: column; flex: 1; padding: var(--space-5); }
  .cat-card__title { display: flex; align-items: center; gap: 10px; font-size: 1.25rem; color: var(--color-forest); text-transform: uppercase; line-height: 1.1; margin-bottom: var(--space-4); }
  .cat-card__title-icon { flex: 0 0 auto; width: 42px; height: 42px; border-radius: 11px; display: grid; place-items: center; border: 1.5px solid var(--color-rust); background: rgba(219,122,34,0.07); color: var(--color-rust); }

  .cat-card__list { display: grid; gap: 10px; margin-bottom: var(--space-5); flex: 1; }
  .cat-card__list li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.96rem; color: var(--color-text); }
  .cat-card__check { color: var(--color-rust); flex: 0 0 auto; margin-top: 2px; }

  .cat-card__actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .cat-card__cta { flex: 1 1 auto; padding: 12px 16px; font-size: 0.92rem; }
  .cat-card__more { flex: 1 1 auto; padding: 12px 16px; font-size: 0.92rem; }

  @media (max-width: 1000px) { .services__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .services__grid { grid-template-columns: 1fr; } }
</style>
