---
/* Užklausos forma (reusable) — inline IR modale (PRD §4.9 / §4.12).
   Web3Forms + hCaptcha raktai išsaugoti iš veikiančios svetainės (site.js). */
import { site } from '@data/site.js';
import Icon from './Icon.astro';
const {
  id = 'contact-form',
  subject = 'Nauja užklausa iš ArbCut svetainės',
  idPrefix = 'f',
} = Astro.props;
---
<form class="contact-form" action="https://api.web3forms.com/submit" method="POST" novalidate id={id}>
  <input type="hidden" name="access_key" value={site.web3formsKey} />
  <input type="hidden" name="subject" value={subject} />
  <input type="hidden" name="from_name" value="ArbCut svetainė" />
  <input type="hidden" name="redirect" value="https://arbcut.lt/success" />
  <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

  <div class="contact-form__row">
    <div class="form-field">
      <label class="form-field__label" for={`${idPrefix}-name`}>Vardas <span class="form-field__required" aria-hidden="true">*</span></label>
      <input class="form-field__input" type="text" id={`${idPrefix}-name`} name="Vardas" autocomplete="given-name" required placeholder="Vardas Pavardė" />
    </div>
    <div class="form-field">
      <label class="form-field__label" for={`${idPrefix}-contact`}>Telefonas arba el. paštas <span class="form-field__required" aria-hidden="true">*</span></label>
      <input class="form-field__input" type="text" id={`${idPrefix}-contact`} name="Kontaktai" autocomplete="tel" inputmode="tel" required placeholder="+370 6xx xxxxx arba el. paštas" />
    </div>
  </div>

  <div class="form-field">
    <label class="form-field__label" for={`${idPrefix}-city`}>Miestas / vietovė</label>
    <input class="form-field__input" type="text" id={`${idPrefix}-city`} name="Miestas" autocomplete="address-level2" placeholder="pvz. Vilnius, Kaunas…" />
  </div>

  <div class="form-field">
    <label class="form-field__label" for={`${idPrefix}-message`}>Žinutė <span class="form-field__required" aria-hidden="true">*</span></label>
    <textarea class="form-field__input form-field__input--textarea" id={`${idPrefix}-message`} name="Žinutė" required rows="5" placeholder="Trumpai aprašykite, ko reikia — medžio dydis, vieta, skubumas…"></textarea>
  </div>

  <div class="h-captcha" data-sitekey={site.hcaptchaSiteKey} style="margin-bottom:1rem;"></div>

  <div class="contact-form__footer">
    <button type="submit" class="btn btn--call btn--large contact-form__submit">
      <Icon name="rodykle" size={18} stroke={2.5} /> Siųsti užklausą
    </button>
    <p class="contact-form__note">* — privalomi laukai</p>
  </div>
</form>

<style>
  .contact-form { display: grid; gap: var(--space-4); }
  .contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .form-field { display: grid; gap: 6px; }
  .form-field__label { font-size: 0.86rem; font-weight: 600; color: var(--color-text); }
  .form-field__required { color: var(--color-rust); }
  .form-field__input {
    width: 100%; padding: 13px 15px; border-radius: var(--radius);
    border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text);
    transition: border-color var(--t-base);
  }
  .form-field__input:focus { outline: none; border-color: var(--color-rust); }
  .form-field__input--textarea { resize: vertical; min-height: 110px; }
  .contact-form__footer { display: flex; align-items: center; gap: var(--space-5); flex-wrap: wrap; }
  .contact-form__note { font-size: 0.82rem; color: var(--color-text-muted); }
  .contact-form.is-submitting .contact-form__submit { opacity: 0.7; pointer-events: none; }
  /* hCaptcha — fiksuoto ~300px pločio; mažuose ekranuose sutalpiname be perpildymo */
  .contact-form .h-captcha { overflow: hidden; }
  @media (max-width: 560px) { .contact-form__row { grid-template-columns: 1fr; } }
  @media (max-width: 400px) {
    .contact-form .h-captcha { transform: scale(0.9); transform-origin: left top; height: 70px; }
  }
</style>
