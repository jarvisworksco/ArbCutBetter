---
/* Vietovių sekcija — aptarnaujami miestai + nuorodos į /[vietove] (lokalus SEO). */
import { vietoves } from '@data/vietoves.js';
import Icon from './Icon.astro';
---
<section class="vietoves section section--forest" id="vietoves" aria-label="Aptarnaujamos vietovės">
  <div class="container">
    <div class="section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center eyebrow--light">KUR DIRBAME</span>
      <h2 class="section-title section-title--light">Aptarnaujame visą Lietuvą</h2>
      <p>Bazė — Kaunas; išvykstame į visus regionus. Pasirinkite miestą arba tiesiog skambinkite.</p>
    </div>

    <ul class="vietoves__grid js-reveal-scroll" role="list">
      {vietoves.map((v) => (
        <li>
          <a href={`/${v.slug}`} class="vietoves__chip">
            <Icon name="vieta" size={18} />
            <span>{v.miestas}</span>
            {v.pagrindinis && <span class="vietoves__badge" title="Pagrindinė bazė">bazė</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .vietoves__grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: var(--space-4); margin-top: var(--space-6); }
  .vietoves__chip { display: flex; align-items: center; gap: 10px; min-width: 0; padding: 14px 16px; background: rgba(241,236,224,0.07); border: 1px solid rgba(241,236,224,0.15); border-radius: var(--radius); color: var(--color-text-light); font-weight: 600; transition: background var(--t-base), border-color var(--t-base), transform var(--t-base); }
  .vietoves__chip svg { color: var(--color-amber); flex: 0 0 auto; }
  .vietoves__chip > span:first-of-type { flex: 1; min-width: 0; }
  .vietoves__chip:hover { background: rgba(241,236,224,0.12); border-color: var(--color-amber); transform: translateY(-2px); }
  .vietoves__badge { flex: 0 0 auto; align-self: center; font-size: 0.6rem; line-height: 1; text-transform: uppercase; letter-spacing: 0.09em; font-weight: 700; color: var(--color-amber); background: rgba(240,169,74,0.16); border: 1px solid rgba(240,169,74,0.4); padding: 4px 8px; border-radius: 5px; }
  @media (max-width: 900px) { .vietoves__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 540px) {
    .vietoves__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-3); }
    .vietoves__chip { padding: 12px 12px; gap: 8px; font-size: 0.92rem; }
    .vietoves__badge { font-size: 0.55rem; padding: 3px 6px; }
  }
</style>
