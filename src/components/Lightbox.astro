---
/* Galerijos lightbox (valdymas site.js). */
---
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Nuotraukos peržiūra" hidden>
  <button class="lightbox__close" aria-label="Uždaryti">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="lightbox__prev" aria-label="Ankstesnė nuotrauka">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <div class="lightbox__stage">
    <img class="lightbox__img" src="" alt="" />
    <p class="lightbox__caption"></p>
  </div>
  <button class="lightbox__next" aria-label="Kita nuotrauka">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<style>
  .lightbox { position: fixed; inset: 0; z-index: 1700; display: flex; align-items: center; justify-content: center; gap: var(--space-4); padding: 24px; background: rgba(15,21,18,0.92); }
  .lightbox[hidden] { display: none; }
  .lightbox__stage { max-width: min(1100px, 92vw); max-height: 86vh; display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .lightbox__img { max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: 4px; }
  .lightbox__caption { color: var(--color-text-light); font-size: 0.9rem; opacity: 0.8; }
  .lightbox__close, .lightbox__prev, .lightbox__next { color: var(--color-text-light); width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center; background: rgba(244,239,230,0.1); transition: background var(--t-base); flex: 0 0 auto; }
  .lightbox__close:hover, .lightbox__prev:hover, .lightbox__next:hover { background: rgba(244,239,230,0.22); }
  .lightbox__close { position: absolute; top: 20px; right: 20px; }
  @media (max-width: 640px) { .lightbox__prev, .lightbox__next { position: absolute; bottom: 24px; } .lightbox__prev { left: 30%; } .lightbox__next { right: 30%; } }
</style>
