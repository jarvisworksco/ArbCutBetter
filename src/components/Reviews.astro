---
/* Atsiliepimai — REALŪS iš paslaugos.lt (5,0 / 106). Pagrindiniame puslapyje
   rodome agreguotą reitingą + 6 atsiliepimus + nuorodą į pilną profilį.
   ⚠️ Jokių prasimanytų atsiliepimų (PRD §10). */
import { atsiliepimai, atsiliepimuVidurkis, atsiliepimuKiekis, atsiliepimuSaltinis } from '@data/atsiliepimai.js';
import { site } from '@data/site.js';
import Icon from './Icon.astro';
const paliktiUrl = site.atsiliepimai.paliktiUrl;
const { limit = 6 } = Astro.props;
const rodomi = atsiliepimai.slice(0, limit);
const vidurkisStr = atsiliepimuVidurkis.toFixed(1).replace('.', ',');
---
<section class="reviews section section--cream" id="atsiliepimai" aria-label="Atsiliepimai">
  <div class="container">
    <div class="section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center">KĄ SAKO KLIENTAI</span>
      <h2 class="section-title">Atsiliepimai</h2>
    </div>

    <div class="reviews__agg js-reveal-scroll">
      <span class="reviews__agg-num">{vidurkisStr}</span>
      <span class="reviews__agg-stars" aria-hidden="true">★★★★★</span>
      <span class="reviews__agg-label">{atsiliepimuKiekis} atsiliepimų · paslaugos.lt</span>
    </div>

    <div class="reviews__grid">
      {rodomi.map((a) => (
        <figure class="review-card js-reveal-scroll">
          <div class="stars" aria-label={`${a.zvaigzdes} iš 5`}>{'★'.repeat(a.zvaigzdes)}</div>
          <blockquote class="review-card__text">„{a.tekstas}"</blockquote>
          <figcaption class="review-card__foot">
            <span class="review-card__name">{a.vardas}</span>
            <span class="review-card__src">paslaugos.lt</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="reviews__cta js-reveal-scroll">
      <a href={atsiliepimuSaltinis} class="btn btn--outline" target="_blank" rel="noopener">
        <Icon name="zvaigzde" size={18} /> Skaityti visus {atsiliepimuKiekis} atsiliepimų
      </a>
    </div>

    <div class="review-leave js-reveal-scroll" data-review-gate={paliktiUrl}>
      <p class="review-leave__title">Naudojotės ArbCut paslaugomis? Įvertinkite mus:</p>
      <div class="review-stars" role="group" aria-label="Įvertinkite žvaigždutėmis nuo 1 iki 5">
        {[1, 2, 3, 4, 5].map((n) => (
          <button type="button" class="review-stars__btn" data-rating={n} aria-label={`${n} žvaigždutės`}>★</button>
        ))}
      </div>
      <p class="review-stars__hint">Pasirinkite žvaigždučių skaičių — nukreipsime į atsiliepimo formą.</p>
    </div>
  </div>
</section>

<style>
  .reviews__agg { display: flex; align-items: center; justify-content: center; gap: var(--space-4); margin-bottom: var(--space-7); flex-wrap: wrap; }
  .reviews__agg-num { font-family: var(--font-display); font-size: 3rem; line-height: 1; color: var(--color-forest); }
  .reviews__agg-stars { color: var(--color-rust); letter-spacing: 3px; font-size: 1.4rem; }
  .reviews__agg-label { font-size: 0.95rem; color: var(--color-text-muted); }

  .reviews__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .review-card { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-6); box-shadow: var(--shadow-card); display: flex; flex-direction: column; gap: var(--space-3); transition: transform var(--t-base), box-shadow var(--t-base); }
  .review-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-heavy); }
  .review-card .stars { font-size: 1rem; }
  .review-card__text { font-size: 1rem; line-height: 1.6; color: var(--color-text); }
  .review-card__foot { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: var(--space-2); }
  .review-card__name { font-weight: 700; }
  .review-card__src { font-size: 0.8rem; color: var(--color-text-muted); }

  .reviews__cta { text-align: center; margin-top: var(--space-7); }

  /* Palikti atsiliepimą — žvaigždučių srautas */
  .review-leave { margin-top: var(--space-7); text-align: center; padding: var(--space-6); background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); max-width: 540px; margin-inline: auto; box-shadow: var(--shadow-card); }
  .review-leave__title { font-weight: 700; color: var(--color-forest); margin-bottom: var(--space-3); }
  .review-stars { display: inline-flex; gap: 6px; }
  .review-stars__btn { font-size: 2.4rem; line-height: 1; color: var(--color-border); transition: color var(--t-fast), transform var(--t-fast); }
  .review-stars__btn:hover { transform: scale(1.12); }
  .review-stars__btn.is-on { color: var(--color-rust); }
  .review-stars__hint { margin-top: var(--space-3); font-size: 0.88rem; color: var(--color-text-muted); min-height: 1.2em; }

  @media (max-width: 980px) { .reviews__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .reviews__grid { grid-template-columns: 1fr; } }
</style>
