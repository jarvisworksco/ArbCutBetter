---
/* 4.9 Inline užklausos forma. */
import { site } from '@data/site.js';
import InquiryForm from './InquiryForm.astro';
---
<section class="contact-form-section section section--cream" id="kontaktai" aria-label="Užklausos forma">
  <div class="container">
    <div class="contact-form__header section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center">SUSISIEKTI</span>
      <h2 class="section-title">Palikite užklausą</h2>
      <p class="contact-form__subtext">
        Atsakysime per vieną darbo dieną. Arba skambinkite tiesiogiai:
        <a href={site.telefonasHref} class="contact-form__phone-link">{site.telefonas}</a>.
      </p>
    </div>

    <div class="contact-form__wrap js-reveal-scroll">
      <InquiryForm id="contact-form" idPrefix="f" subject="Nauja užklausa iš ArbCut svetainės" />
    </div>
  </div>
</section>

<style>
  .contact-form__subtext { font-size: 1.05rem; }
  .contact-form__phone-link { color: var(--color-rust); font-weight: 600; }
  .contact-form__wrap { max-width: 720px; margin-inline: auto; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: clamp(22px, 4vw, 40px); box-shadow: var(--shadow-card); }
</style>
