---
/* 4.12 Užklausos modalas (atidaro bet kuris [data-modal-trigger]). */
import { site } from '@data/site.js';
import InquiryForm from './InquiryForm.astro';
---
<div class="inquiry-modal" id="inquiry-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title" hidden>
  <div class="inquiry-modal__backdrop"></div>
  <div class="inquiry-modal__panel">
    <button class="inquiry-modal__close" aria-label="Uždaryti">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h2 class="inquiry-modal__title" id="modal-title">Palikti užklausą</h2>
    <p class="inquiry-modal__sub">
      Atsakysime per vieną darbo dieną. Arba skambinkite tiesiogiai:
      <a href={site.telefonasHref} class="contact-form__phone-link">{site.telefonas}</a>.
    </p>
    <InquiryForm id="modal-contact-form" idPrefix="m" subject="Nauja užklausa iš ArbCut svetainės (modalas)" />
  </div>
</div>

<style>
  .inquiry-modal { position: fixed; inset: 0; z-index: 1600; display: flex; align-items: center; justify-content: center; padding: 16px; }
  .inquiry-modal[hidden] { display: none; }
  .inquiry-modal__backdrop { position: absolute; inset: 0; background: rgba(15,21,18,0.72); backdrop-filter: blur(4px); }
  .inquiry-modal__panel { position: relative; width: 100%; max-width: 520px; max-height: calc(100svh - 32px); overflow-y: auto; background: var(--color-bg-cream); border-radius: var(--radius); padding: clamp(22px, 4vw, 36px); box-shadow: var(--shadow-heavy); animation: modal-in 250ms cubic-bezier(0.16,1,0.3,1); }
  @keyframes modal-in { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .inquiry-modal__panel { animation: none; } }
  .inquiry-modal__close { position: absolute; top: 14px; right: 14px; width: 36px; height: 36px; border-radius: 50%; display: grid; place-items: center; color: var(--color-text); background: rgba(26,31,28,0.06); }
  .inquiry-modal__close:hover { background: rgba(26,31,28,0.12); }
  .inquiry-modal__title { font-size: 1.8rem; margin-bottom: 6px; }
  .inquiry-modal__sub { font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: var(--space-5); }
  .inquiry-modal .contact-form__phone-link { color: var(--color-rust); font-weight: 600; }
</style>
