---
/* Pokalbių robotas — NEMOKAMA rule-based versija (be API, be kaštų).
   Atsako į paruoštus DUK klausimus, „Palikti užklausą" atidaro formą,
   apačioje visada „Skambinti". Jokio backend'o nereikia. */
import { site } from '@data/site.js';
import Icon from './Icon.astro';
---
<div class="chat-widget" data-chat-widget>
  <button class="chat-widget__toggle" id="chat-toggle" aria-expanded="false" aria-controls="chat-panel" aria-label="Atidaryti pokalbį">
    <Icon name="pokalbis" size={26} stroke={2} />
    <span class="chat-widget__dot" aria-hidden="true"></span>
  </button>

  <div class="chat-widget__panel" id="chat-panel" role="dialog" aria-label="ArbCut pokalbis" hidden>
    <div class="chat-widget__head">
      <span class="chat-widget__head-title">
        <img src="/assets/logo-stacked-light.svg" alt="ArbCut" class="chat-widget__logo" width="40" height="40" />
        <span class="chat-widget__head-text">
          <strong>ArbCut pagalba</strong>
          <small><span class="chat-widget__online"></span> Atsakome darbo metu 8:00–18:00</small>
        </span>
      </span>
      <button class="chat-widget__close" aria-label="Uždaryti pokalbį">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="chat-widget__body" id="chat-body" aria-live="polite">
      <div class="chat-msg chat-msg--bot">
        Sveiki! Esu ArbCut padėjėjas. Pasirinkite klausimą arba paskambinkite.
      </div>
    </div>

    <div class="chat-widget__quick" id="chat-quick">
      <button type="button" class="chat-chip" data-q="kaina">Kiek kainuoja?</button>
      <button type="button" class="chat-chip" data-q="avarine">Avarinė / skubu</button>
      <button type="button" class="chat-chip" data-q="paslaugos">Kokios paslaugos?</button>
      <button type="button" class="chat-chip" data-q="vietove">Ar atvykstate pas mane?</button>
      <button type="button" class="chat-chip chat-chip--accent" data-q="uzklausa">Palikti užklausą</button>
    </div>

    <div class="chat-widget__foot">
      <a href={site.telefonasHref} class="btn btn--call btn--block"><Icon name="telefonas" size={18} stroke={2.5} /> Skambinti {site.telefonas}</a>
    </div>
  </div>
</div>

<script>
  (function () {
    const body = document.getElementById('chat-body');
    const quick = document.getElementById('chat-quick');
    if (!body || !quick) return;

    const ANSWERS = {
      kaina:
        'Kaina priklauso nuo darbo apimties ir sudėtingumo. Orientaciniai įkainiai: medžio pjovimas ir genėjimas — nuo 50 €, kelmų frezavimas — nuo 75 €, šakų išvežimas — nuo 80 €. Tikslią kainą pasakome nemokamai įvertinę vietoje arba pagal nuotraukas.',
      avarine:
        'Atvykstame operatyviai, ypač avarinėmis situacijomis (užvirtęs ar pavojingai pasviręs medis). Dirbame kasdien 08:00–18:00. Skubiu atveju geriausia iškart paskambinti — aptarsime greičiausią sprendimą.',
      paslaugos:
        'Pagrindinės paslaugos: pavojingų medžių pjovimas, genėjimas, kelmų naikinimas, darbai su autobokšteliu (iki 20 m), šakų išvežimas, lajos stabilizavimas, gyvatvorių karpymas ir kiti aukštuminiai darbai. Visą sąrašą rasite skiltyje „Paslaugos".',
      vietove:
        'Dirbame visoje Lietuvoje (bazė — Kaunas). Šakas ir medieną fiskaru išvežame Kaune ir Kauno rajone; toliau medieną paliekame tvarkingoje krūvoje. Parašykite savo miestą skambučiu — pasakysime tiksliau.',
    };
    const LABEL = { kaina: 'Kiek kainuoja?', avarine: 'Avarinė / skubu', paslaugos: 'Kokios paslaugos?', vietove: 'Ar atvykstate pas mane?', uzklausa: 'Palikti užklausą' };

    function bubble(text, who) {
      const el = document.createElement('div');
      el.className = 'chat-msg chat-msg--' + who;
      el.textContent = text;
      body.appendChild(el);
      body.scrollTop = body.scrollHeight;
    }

    function ask(q) {
      bubble(LABEL[q] || q, 'user');
      if (q === 'uzklausa') {
        bubble('Puiku! Atidarau trumpą užklausos formą — užtenka vardo ir telefono.', 'bot');
        const t = document.querySelector('[data-modal-trigger]');
        setTimeout(() => t && t.click(), 350);
        return;
      }
      setTimeout(() => bubble(ANSWERS[q], 'bot'), 240);
    }

    quick.addEventListener('click', (e) => {
      const btn = e.target.closest('.chat-chip');
      if (!btn) return;
      ask(btn.dataset.q);
    });
  })();
</script>

<style>
  .chat-widget__toggle { position: fixed; right: 16px; bottom: 20px; z-index: 1150; width: 58px; height: 58px; border-radius: 50%; display: grid; place-items: center; background: var(--color-forest); color: var(--color-text-light); box-shadow: var(--shadow-heavy); transition: transform var(--t-base), background var(--t-base); }
  .chat-widget__toggle:hover { transform: translateY(-2px); background: var(--color-forest-deep); }
  .chat-widget__dot { position: absolute; top: 10px; right: 12px; width: 10px; height: 10px; border-radius: 50%; background: var(--color-rust); border: 2px solid var(--color-forest); }
  @media (min-width: 768px) { .chat-widget__toggle { bottom: 24px; } }

  .chat-widget__panel { position: fixed; right: 16px; bottom: 88px; z-index: 1150; width: min(360px, calc(100vw - 32px)); background: var(--color-bg-cream); border: 1px solid var(--color-border); border-radius: 14px; box-shadow: var(--shadow-heavy); overflow: hidden; display: flex; flex-direction: column; max-height: min(560px, calc(100vh - 120px)); }
  .chat-widget__panel[hidden] { display: none; }
  @media (min-width: 768px) { .chat-widget__panel { bottom: 96px; } }

  .chat-widget__head { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; background: var(--color-forest); color: var(--color-text-light); }
  .chat-widget__head-title { display: flex; align-items: center; gap: 11px; }
  .chat-widget__logo { width: 40px; height: 40px; flex: 0 0 auto; }
  .chat-widget__head-text { display: flex; flex-direction: column; gap: 2px; }
  .chat-widget__head-text strong { font-size: 0.98rem; line-height: 1.1; }
  .chat-widget__head-title small { display: flex; align-items: center; gap: 6px; opacity: 0.82; font-size: 0.72rem; }
  .chat-widget__online { width: 7px; height: 7px; border-radius: 50%; background: #5ED17A; display: inline-block; flex: 0 0 auto; }
  .chat-widget__close { color: var(--color-text-light); }

  .chat-widget__body { padding: 14px; display: flex; flex-direction: column; gap: 9px; overflow-y: auto; flex: 1; }
  .chat-msg { max-width: 90%; padding: 9px 12px; border-radius: 12px; font-size: 0.88rem; line-height: 1.45; }
  .chat-msg--bot { background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-text); align-self: flex-start; border-bottom-left-radius: 4px; }
  .chat-msg--user { background: var(--color-forest); color: var(--color-text-light); align-self: flex-end; border-bottom-right-radius: 4px; }

  .chat-widget__quick { display: flex; flex-wrap: wrap; gap: 7px; padding: 0 14px 12px; }
  .chat-chip { padding: 8px 12px; border-radius: 20px; border: 1.5px solid var(--color-border); background: var(--color-bg-card); font-size: 0.82rem; font-weight: 600; color: var(--color-forest); transition: border-color var(--t-base), background var(--t-base); }
  .chat-chip:hover { border-color: var(--color-rust); background: var(--color-bg-sand); }
  .chat-chip--accent { background: var(--color-rust); color: #fff; border-color: var(--color-rust); }
  .chat-chip--accent:hover { background: var(--color-rust-hover); }

  .chat-widget__foot { padding: 12px 14px 14px; border-top: 1px solid var(--color-border); }
  .chat-widget__foot .btn { font-size: 0.9rem; padding: 11px 14px; }
</style>
