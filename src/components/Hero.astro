---
/* HERO — konversinis pirmas ekranas: kairėje žinutė + reitingas + CTA,
   dešinėje trumpa užklausos forma (Web3Forms). Fonas — reali darbo nuotrauka
   su giliu žaliu perdengimu ir subtiliu Ken Burns priartinimu. */
import { site } from '@data/site.js';
import { atsiliepimuVidurkis, atsiliepimuKiekis } from '@data/atsiliepimai.js';
import Icon from './Icon.astro';
const heroPhoto = '/assets/images/gallery/hero.jpg';
const vidurkisStr = atsiliepimuVidurkis.toFixed(1).replace('.', ',');
---
<section class="hero" id="hero" aria-label="Pagrindinis blokas">
  <div class="hero__bg" aria-hidden="true">
    <img src={heroPhoto} alt="" class="hero__bg-img" loading="eager" fetchpriority="high" />
    <div class="hero__bg-overlay"></div>
  </div>

  <div class="hero__inner container">
    <div class="hero__text">
      <span class="hero__eyebrow js-reveal">Arboristas · Aukštalipys · Visa Lietuva</span>

      <h1 class="hero__headline js-reveal">
        Medžių priežiūra ir <br />aukštuminiai darbai — <br /><span class="hero__accent">saugiai ir iki galo.</span>
      </h1>

      <p class="hero__subheadline js-reveal">
        Kvalifikuotas arboristas aukštalipys su komanda. Pjauname pavojingus medžius,
        genime, šaliname kelmus ir dirbame aukštyje iki 20 m nuosavu autobokšteliu — visoje Lietuvoje.
      </p>

      <a class="hero__rating js-reveal" href="#atsiliepimai" aria-label={`Įvertinimas ${vidurkisStr} iš 5, ${atsiliepimuKiekis} atsiliepimų`}>
        <span class="hero__stars" aria-hidden="true">★★★★★</span>
        <span class="hero__rating-text"><strong>{vidurkisStr}</strong> · {atsiliepimuKiekis}+ atsiliepimų paslaugos.lt</span>
      </a>

      <div class="hero__ctas js-reveal">
        <a href={site.telefonasHref} class="btn btn--call btn--large">
          <Icon name="telefonas" size={20} stroke={2.5} /> {site.telefonas}
        </a>
        <a href="#paslaugos" class="btn btn--outline-light btn--large">Žiūrėti paslaugas</a>
      </div>

      <ul class="hero__trust js-reveal" role="list">
        <li><Icon name="autobokstelis" size={18} /> Nuosavas autobokštelis (20 m)</li>
        <li><Icon name="vieta" size={18} /> Dirbame visoje Lietuvoje</li>
        <li><Icon name="ivertinimas" size={18} /> Nemokamas įvertinimas</li>
      </ul>
    </div>

    <div class="hero__form-col js-reveal">
      <div class="hero-form-card">
        <h2 class="hero-form-card__title">Gaukite nemokamą pasiūlymą</h2>
        <p class="hero-form-card__sub">Aprašykite darbą — susisieksime ir pateiksime preliminarią kainą. Be įsipareigojimų.</p>

        <form class="hero-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
          <input type="hidden" name="access_key" value={site.web3formsKey} />
          <input type="hidden" name="subject" value="Nauja užklausa iš ArbCut (hero)" />
          <input type="hidden" name="from_name" value="ArbCut svetainė" />
          <input type="hidden" name="redirect" value="https://arbcut.lt/success" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

          <div class="hero-form__field">
            <label for="hero-name">Vardas</label>
            <input id="hero-name" name="Vardas" type="text" required autocomplete="given-name" placeholder="Jūsų vardas" />
          </div>
          <div class="hero-form__field">
            <label for="hero-phone">Telefonas</label>
            <input id="hero-phone" name="Telefonas" type="tel" inputmode="tel" required autocomplete="tel" placeholder="+370 6xx xxxxx" />
          </div>
          <div class="hero-form__field">
            <label for="hero-msg">Trumpai apie darbą</label>
            <textarea id="hero-msg" name="Žinutė" rows="3" required placeholder="pvz. nupjauti pavojingą medį prie namo, Kaunas"></textarea>
          </div>

          <div class="h-captcha" data-sitekey={site.hcaptchaSiteKey}></div>

          <button type="submit" class="btn btn--call btn--large btn--block">
            <Icon name="rodykle" size={18} stroke={2.5} /> Siųsti užklausą
          </button>
          <p class="hero-form__or">arba skambinkite <a href={site.telefonasHref}>{site.telefonas}</a></p>
        </form>
      </div>
    </div>
  </div>

  <a href="#paslaugos" class="hero__scroll" aria-label="Slinkti žemyn">
    <Icon name="chevron" size={26} stroke={2} />
  </a>
</section>

<style>
  .hero { position: relative; min-height: 100vh; display: flex; align-items: center; color: var(--color-text-light); padding-top: calc(var(--header-height) + 40px); padding-bottom: var(--space-9); overflow: hidden; background: var(--color-forest-deep); }

  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; animation: kenburns 22s ease-out forwards; }
  @keyframes kenburns { from { transform: scale(1.08); } to { transform: scale(1); } }
  .hero__bg-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(105deg, rgba(14,42,28,0.94) 0%, rgba(14,42,28,0.82) 42%, rgba(14,42,28,0.55) 100%),
      linear-gradient(to top, rgba(14,26,20,0.85) 0%, rgba(14,26,20,0) 55%);
  }

  .hero__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.15fr 0.85fr; gap: var(--space-8); align-items: center; width: 100%; }
  .hero__text, .hero__form-col { min-width: 0; }

  .hero__eyebrow { display: inline-block; font-weight: 700; text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.8rem; color: var(--color-amber); margin-bottom: var(--space-4); }
  .hero__headline { font-size: clamp(2rem, 5.2vw, 5rem); color: #fff; text-transform: uppercase; line-height: 1.08; margin-bottom: var(--space-5); overflow-wrap: break-word; hyphens: auto; }
  .hero__accent { color: var(--color-amber); }
  .hero__subheadline { font-size: clamp(1.05rem, 1.4vw, 1.25rem); color: rgba(241,236,224,0.92); max-width: 580px; margin-bottom: var(--space-5); }

  .hero__rating { display: inline-flex; align-items: center; gap: 10px; margin-bottom: var(--space-6); }
  .hero__stars { color: var(--color-amber); letter-spacing: 2px; font-size: 1.1rem; }
  .hero__rating-text { font-size: 0.95rem; color: rgba(241,236,224,0.9); }
  .hero__rating-text strong { color: #fff; }

  .hero__ctas { display: flex; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-6); }

  .hero__trust { display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-5); }
  .hero__trust li { display: inline-flex; align-items: center; gap: 8px; font-size: 0.92rem; color: rgba(241,236,224,0.85); }
  .hero__trust svg { color: var(--color-amber); flex: 0 0 auto; }

  /* --- Form card --- */
  .hero__form-col { display: flex; justify-content: flex-end; }
  .hero-form-card { width: 100%; max-width: 420px; background: rgba(255,255,255,0.97); color: var(--color-text); border-radius: 12px; padding: var(--space-6); box-shadow: var(--shadow-heavy); border-top: 4px solid var(--color-rust); }
  .hero-form-card__title { font-size: 1.5rem; color: var(--color-forest); }
  .hero-form-card__sub { font-size: 0.92rem; color: var(--color-text-muted); margin: 8px 0 var(--space-5); line-height: 1.5; }
  .hero-form { display: grid; gap: var(--space-4); }
  .hero-form__field { display: grid; gap: 5px; }
  .hero-form__field label { font-size: 0.82rem; font-weight: 600; }
  .hero-form input, .hero-form textarea { width: 100%; padding: 12px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text); transition: border-color var(--t-base); }
  .hero-form input:focus, .hero-form textarea:focus { outline: none; border-color: var(--color-rust); }
  .hero-form textarea { resize: vertical; }
  .hero-form .h-captcha { min-height: 0; }
  .hero-form__or { text-align: center; font-size: 0.9rem; color: var(--color-text-muted); }
  .hero-form__or a { color: var(--color-rust); font-weight: 700; }

  .hero__scroll { position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); z-index: 1; color: rgba(241,236,224,0.7); animation: bob 1.8s ease-in-out infinite; }
  @keyframes bob { 0%,100%{transform:translate(-50%,0);} 50%{transform:translate(-50%,8px);} }

  @media (max-width: 1023px) {
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-7); }
    .hero__form-col { justify-content: stretch; }
    .hero-form-card { max-width: 100%; }
    .hero__scroll { display: none; }
  }
  @media (max-width: 600px) {
    .hero { min-height: 0; padding-top: calc(var(--header-height) + 28px); }
    .hero__headline { font-size: clamp(1.85rem, 9vw, 2.6rem); line-height: 1.16; }
    .hero__headline br { display: none; }
    .hero__ctas .btn { width: 100%; }
    .hero__rating { flex-wrap: wrap; }
  }
  /* hCaptcha valdiklis fiksuoto ~300px pločio — mažuose telefonuose sutalpiname */
  @media (max-width: 430px) {
    .hero-form-card { padding: var(--space-5); }
    .hero-form .h-captcha { transform: scale(0.86); transform-origin: left top; height: 68px; overflow: hidden; }
  }
</style>
