---
/* „Kaip dirbame" — 4 žingsniai su jungiamąja linija (konversijos aiškumas). */
import { procesas } from '@data/turinys.js';
import Icon from './Icon.astro';
---
<section class="process section section--cream" id="kaip-dirbame" aria-label="Kaip dirbame">
  <div class="container">
    <div class="section-head section-head--center js-reveal-scroll">
      <span class="eyebrow eyebrow--center">PAPRASTA IR AIŠKU</span>
      <h2 class="section-title">Kaip dirbame</h2>
      <p>Nuo pirmo skambučio iki sutvarkytos aplinkos — keturi aiškūs žingsniai.</p>
    </div>

    <div class="process__grid">
      <div class="process__line" aria-hidden="true"></div>
      {procesas.map((z, i) => (
        <div class="process__step js-reveal-scroll" style={`--reveal-delay:${i * 110}ms`}>
          <span class="process__num">{i + 1}</span>
          <span class="process__icon"><Icon name={z.ikona} size={28} /></span>
          <h3 class="process__title">{z.pavadinimas}</h3>
          <p class="process__desc">{z.tekstas}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process__grid { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); }
  .process__line { position: absolute; top: 34px; left: 12%; right: 12%; height: 2px; background: var(--color-border); }
  .process__step { text-align: center; position: relative; }
  .process__icon { width: 68px; height: 68px; margin: 0 auto var(--space-4); border-radius: 50%; display: grid; place-items: center; background: var(--color-bg-cream); color: var(--color-rust); border: 2px solid var(--color-rust); position: relative; z-index: 1; }
  .process__num { position: absolute; top: -4px; left: calc(50% + 18px); width: 24px; height: 24px; border-radius: 50%; background: var(--color-forest); color: var(--color-text-light); font-family: var(--font-display); font-size: 0.8rem; display: grid; place-items: center; z-index: 2; }
  .process__title { font-size: 1.2rem; margin-bottom: 6px; }
  .process__desc { font-size: 0.92rem; color: var(--color-text-muted); }
  @media (max-width: 820px) { .process__grid { grid-template-columns: 1fr 1fr; gap: var(--space-7) var(--space-5); } .process__line { display: none; } }
  @media (max-width: 460px) { .process__grid { grid-template-columns: 1fr; } }
</style>
