---
/* Pasitikėjimo juosta su count-up (konversijos akcentas). Statai iš site.js. */
import { site } from '@data/site.js';
---
<section class="trust-strip" aria-label="ArbCut skaičiais">
  <div class="container trust-strip__grid">
    {site.statai.map((s) => (
      <div class="trust-stat js-reveal-scroll">
        <strong class="trust-stat__num">
          {s.tekstas
            ? s.tekstas
            : <span data-count={s.skaicius} data-suffix={s.priesaga || ''}>{s.skaicius}{s.priesaga || ''}</span>}
        </strong>
        <span class="trust-stat__label">{s.etikete}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trust-strip { background: var(--color-forest); color: var(--color-text-light); }
  .trust-strip__grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .trust-stat { text-align: center; padding: var(--space-7) var(--space-4); position: relative; }
  .trust-stat:not(:last-child)::after { content: ''; position: absolute; right: 0; top: 28%; height: 44%; width: 1px; background: var(--color-moss); }
  .trust-stat__num { display: block; font-family: var(--font-display); font-size: clamp(2.75rem, 5vw, 4.5rem); line-height: 1; color: var(--color-text-light); }
  .trust-stat__label { display: block; margin-top: var(--space-3); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; opacity: 0.82; max-width: 200px; margin-inline: auto; }
  @media (max-width: 680px) {
    .trust-strip__grid { grid-template-columns: 1fr; }
    .trust-stat:not(:last-child)::after { right: 22%; left: 22%; top: auto; bottom: 0; width: auto; height: 1px; }
  }
</style>
