---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import PageHero from '@components/PageHero.astro';
import Footer from '@components/Footer.astro';
import StickyCall from '@components/StickyCall.astro';
import InquiryModal from '@components/InquiryModal.astro';
import { site } from '@data/site.js';
import { breadcrumbs } from '@data/jsonld.js';

const title = 'Privatumo politika — ArbCut';
const description = 'Kaip ArbCut renka ir naudoja per svetainės užklausos formą pateiktus duomenis.';
const schemas = [breadcrumbs([{ name: 'Pradžia', path: '/' }, { name: 'Privatumo politika', path: '/privatumo-politika' }])];
---
<BaseLayout title={title} description={description} noindex={true} schemas={schemas}>
  <Header />
  <main id="main">
    <PageHero eyebrow="Teisinė informacija" title="Privatumo politika"
      crumbs={[{ name: 'Pradžia', path: '/' }, { name: 'Privatumo politika' }]} />
    <section class="section section--cream">
      <div class="container legal prose">
        <p><em>Atnaujinta: 2026 m.</em></p>
        <p>Ši privatumo politika paaiškina, kaip {site.pavadinimas} ({site.savininkas}) tvarko asmens duomenis, pateiktus per šios svetainės užklausos formą ar susisiekus telefonu bei el. paštu.</p>

        <h2>Kokius duomenis renkame</h2>
        <ul>
          <li>Vardą;</li>
          <li>Kontaktinius duomenis (telefono numerį ir (arba) el. paštą);</li>
          <li>Jūsų žinutę ir su darbu susijusią informaciją (pvz. miestą, darbo aprašymą).</li>
        </ul>
        <p>Renkame tik tuos duomenis, kuriuos pateikiate savanoriškai, norėdami gauti pasiūlymą ar konsultaciją.</p>

        <h2>Kam naudojame duomenis</h2>
        <ul>
          <li>Susisiekti su jumis ir atsakyti į užklausą;</li>
          <li>Pateikti paslaugos pasiūlymą ir suderinti darbus.</li>
        </ul>
        <p>Duomenų nenaudojame reklamai be jūsų sutikimo ir neperduodame trečiosioms šalims, išskyrus tiek, kiek būtina užklausai pristatyti (formos pranešimus tvarko paslauga „Web3Forms", o apsaugai nuo šiukšlių naudojamas „hCaptcha").</p>

        <h2>Saugojimas</h2>
        <p>Užklausų duomenis saugome tiek, kiek reikia jūsų užklausai išnagrinėti ir įprastam bendravimui dėl paslaugų. Vėliau jie pašalinami arba nuasmeninami.</p>

        <h2>Jūsų teisės</h2>
        <p>Galite bet kada kreiptis ir paprašyti susipažinti su savo duomenimis, juos ištaisyti arba ištrinti. Tam susisiekite: <a href={site.telefonasHref}>{site.telefonas}</a> arba <a href={`mailto:${site.elPastas}`}>{site.elPastas}</a>.</p>

        <h2>Slapukai</h2>
        <p>Svetainė nenaudoja sekimo ar rinkodaros slapukų. Funkciniai trečiųjų šalių komponentai (pvz. „hCaptcha", „Google Fonts") gali naudoti techninius slapukus savo veikimui užtikrinti.</p>

        <h2>Kontaktai</h2>
        <p>{site.pavadinimas}, {site.savininkas}<br />Tel.: <a href={site.telefonasHref}>{site.telefonas}</a><br />El. paštas: <a href={`mailto:${site.elPastas}`}>{site.elPastas}</a></p>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCall />
  <InquiryModal />
</BaseLayout>

<style>
  .legal { max-width: 760px; }
  .prose h2 { font-size: clamp(1.4rem, 2.2vw, 1.8rem); color: var(--color-forest); margin: var(--space-6) 0 var(--space-3); text-transform: uppercase; }
  .prose p { margin-bottom: var(--space-4); line-height: 1.8; }
  .prose ul { margin: 0 0 var(--space-4) var(--space-5); display: grid; gap: 8px; }
  .prose li { list-style: disc; }
  .prose a { color: var(--color-rust); font-weight: 600; }
  .prose strong { color: var(--color-forest); }
</style>
