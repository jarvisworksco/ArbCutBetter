---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import PageHero from '@components/PageHero.astro';
import Process from '@components/Process.astro';
import Reviews from '@components/Reviews.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactSection from '@components/ContactSection.astro';
import Footer from '@components/Footer.astro';
import StickyCall from '@components/StickyCall.astro';
import InquiryModal from '@components/InquiryModal.astro';
import ChatWidget from '@components/ChatWidget.astro';
import Icon from '@components/Icon.astro';
import { paslaugos } from '@data/paslaugos.js';
import { site } from '@data/site.js';
import { localBusiness, serviceSchema, breadcrumbs } from '@data/jsonld.js';

export function getStaticPaths() {
  return paslaugos.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const kitos = paslaugos.filter((x) => x.slug !== p.slug).slice(0, 6);

const title = `${p.pavadinimas} — ArbCut | Visoje Lietuvoje`;
const description = `${p.aprasymas} Kaina ${p.kaina}. Skambinkite ${site.telefonas} — nemokamas įvertinimas.`;
const schemas = [
  localBusiness(),
  serviceSchema(p),
  breadcrumbs([
    { name: 'Pradžia', path: '/' },
    { name: 'Paslaugos', path: '/#paslaugos' },
    { name: p.pavadinimas, path: `/paslaugos/${p.slug}` },
  ]),
];
---
<BaseLayout title={title} description={description} ogImage={p.nuotrauka} schemas={schemas}>
  <Header />
  <main id="main">
    <PageHero
      eyebrow="Paslauga"
      title={p.pavadinimas}
      subtitle={p.aprasymas}
      image={p.nuotrauka}
      crumbs={[{ name: 'Pradžia', path: '/' }, { name: 'Paslaugos', path: '/#paslaugos' }, { name: p.pavadinimas }]}
    />

    <section class="section section--cream">
      <div class="container svc">
        <div class="svc__main">
          <div class="svc__price js-reveal-scroll">
            <span class="svc__price-icon"><Icon name={p.ikona} size={28} /></span>
            <div>
              <span class="svc__price-label">Kaina</span>
              <span class="svc__price-value">{p.kaina}</span>
            </div>
            <p class="svc__price-note">Tiksli kaina — įvertinus darbą vietoje arba pagal nuotraukas. Įvertinimas nemokamas.</p>
          </div>

          <div class="svc__text js-reveal-scroll">
            <p>{p.seo}</p>
          </div>

          <div class="svc__points js-reveal-scroll">
            <div class="svc__point"><Icon name="saugu" size={22} /> Saugiai — alpinistinė įranga ir autobokštelis iki 20 m</div>
            <div class="svc__point"><Icon name="vieta" size={22} /> Dirbame visoje Lietuvoje</div>
            <div class="svc__point"><Icon name="svara" size={22} /> Po darbų sutvarkome teritoriją</div>
            <div class="svc__point"><Icon name="zvaigzde" size={22} /> 5,0 ★ įvertinimas (106 atsiliepimai)</div>
          </div>

          <a href={site.telefonasHref} class="btn btn--call btn--large js-reveal-scroll">
            <Icon name="telefonas" size={20} stroke={2.5} /> Skambinti {site.telefonas}
          </a>
        </div>

        <aside class="svc__aside">
          <div class="svc__aside-card js-reveal-scroll">
            <h2 class="svc__aside-title">Kitos paslaugos</h2>
            <ul class="svc__list" role="list">
              {kitos.map((k) => (
                <li>
                  <a href={`/paslaugos/${k.slug}`} class="svc__link">
                    <Icon name={k.ikona} size={20} />
                    <span>{k.pavadinimas}</span>
                    <Icon name="rodykle" size={16} class="svc__link-arrow" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <Process />
    <Reviews limit={3} />
    <CtaBand />
    <ContactSection />
  </main>
  <Footer />
  <StickyCall />
  <InquiryModal />
  <ChatWidget />
  <script src="https://js.hcaptcha.com/1/api.js" async defer is:inline></script>
</BaseLayout>

<style>
  .svc { display: grid; grid-template-columns: 1fr 320px; gap: var(--space-8); align-items: start; }
  .svc__price { display: grid; grid-template-columns: auto 1fr; gap: 4px var(--space-4); align-items: center; background: var(--color-bg-card); border: 1px solid var(--color-border); border-left: 4px solid var(--color-rust); border-radius: var(--radius); padding: var(--space-5); box-shadow: var(--shadow-card); margin-bottom: var(--space-6); }
  .svc__price-icon { grid-row: 1 / 3; width: 56px; height: 56px; border-radius: 50%; display: grid; place-items: center; background: var(--color-forest); color: var(--color-text-light); }
  .svc__price-label { display: block; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); }
  .svc__price-value { font-family: var(--font-display); font-size: 1.8rem; color: var(--color-forest); }
  .svc__price-note { grid-column: 1 / 3; margin-top: 4px; font-size: 0.88rem; color: var(--color-text-muted); }

  .svc__text { font-size: 1.1rem; line-height: 1.75; color: var(--color-text); margin-bottom: var(--space-6); }
  .svc__points { display: grid; gap: var(--space-3); margin-bottom: var(--space-6); }
  .svc__point { display: flex; align-items: center; gap: 12px; font-weight: 600; color: var(--color-forest); }
  .svc__point svg { color: var(--color-rust); flex: 0 0 auto; }

  .svc__aside-card { position: sticky; top: calc(var(--header-height) + 16px); background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-5); box-shadow: var(--shadow-card); }
  .svc__aside-title { font-size: 1.2rem; color: var(--color-forest); margin-bottom: var(--space-4); }
  .svc__list { display: grid; gap: 4px; }
  .svc__link { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--radius-sm); color: var(--color-text); transition: background var(--t-base), color var(--t-base); }
  .svc__link svg:first-child { color: var(--color-rust); flex: 0 0 auto; }
  .svc__link span { flex: 1; font-size: 0.95rem; }
  .svc__link-arrow { opacity: 0; transition: opacity var(--t-base), transform var(--t-base); }
  .svc__link:hover { background: var(--color-bg-sand); color: var(--color-forest); }
  .svc__link:hover .svc__link-arrow { opacity: 1; transform: translateX(2px); }

  @media (max-width: 900px) { .svc { grid-template-columns: 1fr; } .svc__aside-card { position: static; } }
</style>
