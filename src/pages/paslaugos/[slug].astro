---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import PageHero from '@components/PageHero.astro';
import Process from '@components/Process.astro';
import Reviews from '@components/Reviews.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactSection from '@components/ContactSection.astro';
import Footer from '@components/Footer.astro';
import StickyCall from '@components/StickyCall.astro';
import InquiryModal from '@components/InquiryModal.astro';
import ChatWidget from '@components/ChatWidget.astro';
import Icon from '@components/Icon.astro';
import { paslaugos } from '@data/paslaugos.js';
import { site } from '@data/site.js';
import { localBusiness, serviceSchema, breadcrumbs } from '@data/jsonld.js';

export function getStaticPaths() {
  return paslaugos.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const kitos = paslaugos.filter((x) => x.slug !== p.slug).slice(0, 6);

/* Privalumai — ikona „outline box" + paryškintas įvadinis žodis */
const privalumai = [
  { ikona: 'skydas', lead: 'Saugiai', text: 'alpinistinė įranga ir autobokštelis iki 20 m' },
  { ikona: 'vieta', lead: 'Visoje Lietuvoje', text: 'atvykstame į visus regionus' },
  { ikona: 'tvarka', lead: 'Tvarkinga', text: 'po darbų sutvarkome teritoriją' },
  { ikona: 'zvaigzde', lead: '5,0 įvertinimas', text: '106 klientų atsiliepimai' },
];

const title = `${p.pavadinimas} — ArbCut | Visoje Lietuvoje`;
const description = `${p.aprasymas} Kaina ${p.kaina}. Skambinkite ${site.telefonas} — nemokamas įvertinimas.`;
const schemas = [
  localBusiness(),
  serviceSchema(p),
  breadcrumbs([
    { name: 'Pradžia', path: '/' },
    { name: 'Paslaugos', path: '/#paslaugos' },
    { name: p.pavadinimas, path: `/paslaugos/${p.slug}` },
  ]),
];
---
<BaseLayout title={title} description={description} ogImage={p.nuotrauka} schemas={schemas}>
  <Header />
  <main id="main">
    <PageHero
      eyebrow="Paslauga"
      title={p.pavadinimas}
      subtitle={p.aprasymas}
      crumbs={[{ name: 'Pradžia', path: '/' }, { name: 'Paslaugos', path: '/#paslaugos' }, { name: p.pavadinimas }]}
    />

    <section class="section section--cream">
      <div class="container svc">
        <div class="svc__main">
          <div class="svc__price js-reveal-scroll">
            <span class="svc__price-icon" aria-hidden="true"><Icon name={p.ikona} size={26} /></span>
            <div class="svc__price-body">
              <span class="svc__price-label">Kaina</span>
              <span class="svc__price-value">{p.kaina}</span>
            </div>
            <p class="svc__price-note">Tiksli kaina — įvertinus darbą vietoje arba pagal nuotraukas. Įvertinimas nemokamas.</p>
          </div>

          <div class="svc__text js-reveal-scroll">
            <p>{p.seo}</p>
          </div>

          <ul class="svc__benefits js-reveal-scroll" role="list">
            {privalumai.map((b) => (
              <li>
                <span class="svc__benefit-icon" aria-hidden="true"><Icon name={b.ikona} size={22} /></span>
                <span class="svc__benefit-text"><strong>{b.lead}</strong><span>{b.text}</span></span>
              </li>
            ))}
          </ul>

          <a href={site.telefonasHref} class="btn btn--call btn--large js-reveal-scroll">
            <Icon name="telefonas" size={20} stroke={2.5} /> Skambinti {site.telefonas}
          </a>
        </div>

        <aside class="svc__aside">
          <div class="svc__aside-card js-reveal-scroll">
            <h2 class="svc__aside-title">Kitos paslaugos</h2>
            <ul class="svc__list" role="list">
              {kitos.map((k) => (
                <li><a href={`/paslaugos/${k.slug}`}>{k.pavadinimas}</a></li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <Process />
    <Reviews limit={3} />
    <CtaBand />
    <ContactSection />
  </main>
  <Footer />
  <StickyCall />
  <InquiryModal />
  <ChatWidget />
  <script src="https://js.hcaptcha.com/1/api.js" async defer is:inline></script>
</BaseLayout>

<style>
  .svc { display: grid; grid-template-columns: 1fr 300px; gap: var(--space-8); align-items: start; }

  /* „Outline box" ikonos stilius (švarus, su rėmeliu) */
  .svc__price-icon,
  .svc__benefit-icon {
    flex: 0 0 auto; display: grid; place-items: center;
    border: 1.5px solid var(--color-rust); background: rgba(219,122,34,0.07);
    color: var(--color-rust); border-radius: 12px;
  }

  /* Kaina */
  .svc__price { display: grid; grid-template-columns: auto 1fr; gap: 4px var(--space-5); align-items: center; background: var(--color-bg-card); border: 1px solid var(--color-border); border-left: 4px solid var(--color-rust); border-radius: var(--radius); padding: var(--space-5) var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-6); }
  .svc__price-icon { width: 56px; height: 56px; }
  .svc__price-label { display: block; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-text-muted); font-weight: 700; }
  .svc__price-value { display: block; font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.6rem); color: var(--color-forest); line-height: 1; margin-top: 4px; }
  .svc__price-note { grid-column: 1 / -1; margin-top: var(--space-3); font-size: 0.9rem; color: var(--color-text-muted); }

  .svc__text { font-size: 1.1rem; line-height: 1.8; color: var(--color-text); margin-bottom: var(--space-6); }

  /* Privalumai — ikona outline box + tekstas */
  .svc__benefits { margin-bottom: var(--space-6); display: grid; gap: var(--space-3); }
  .svc__benefits li { display: flex; align-items: center; gap: var(--space-4); }
  .svc__benefit-icon { width: 44px; height: 44px; }
  .svc__benefit-text strong { display: block; color: var(--color-forest); font-size: 1.05rem; }
  .svc__benefit-text > span { color: var(--color-text-muted); font-size: 0.95rem; }

  /* Šoninė juosta — teksto nuorodos */
  .svc__aside-card { position: sticky; top: calc(var(--header-height) + 16px); background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-5) var(--space-6); box-shadow: var(--shadow-card); }
  .svc__aside-title { font-size: 1.2rem; color: var(--color-forest); margin-bottom: var(--space-3); }
  .svc__list li { border-bottom: 1px solid var(--color-border); }
  .svc__list li:last-child { border-bottom: none; }
  .svc__list a { display: flex; justify-content: space-between; align-items: center; gap: 10px; padding: 12px 0; color: var(--color-text); font-size: 0.98rem; line-height: 1.35; transition: color var(--t-base); }
  .svc__list a::after { content: '›'; color: var(--color-rust); font-size: 1.2rem; opacity: 0; transform: translateX(-4px); transition: opacity var(--t-base), transform var(--t-base); }
  .svc__list a:hover { color: var(--color-rust); }
  .svc__list a:hover::after { opacity: 1; transform: none; }

  @media (max-width: 900px) {
    .svc { grid-template-columns: 1fr; }
    .svc__aside-card { position: static; }
  }
</style>
