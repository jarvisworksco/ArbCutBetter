---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import PageHero from '@components/PageHero.astro';
import Footer from '@components/Footer.astro';
import StickyCall from '@components/StickyCall.astro';
import InquiryModal from '@components/InquiryModal.astro';
import { site } from '@data/site.js';
import { breadcrumbs } from '@data/jsonld.js';

const title = 'Naudojimosi taisyklės — ArbCut';
const description = 'ArbCut svetainės naudojimosi taisyklės ir bendrosios sąlygos.';
const schemas = [breadcrumbs([{ name: 'Pradžia', path: '/' }, { name: 'Taisyklės', path: '/taisykles' }])];
---
<BaseLayout title={title} description={description} noindex={true} schemas={schemas}>
  <Header />
  <main id="main">
    <PageHero eyebrow="Teisinė informacija" title="Naudojimosi taisyklės"
      crumbs={[{ name: 'Pradžia', path: '/' }, { name: 'Taisyklės' }]} />
    <section class="section section--cream">
      <div class="container legal prose">
        <p><em>Atnaujinta: 2026 m.</em></p>
        <p>Šios taisyklės taikomos naudojantis {site.pavadinimas} svetaine. Naudodamiesi svetaine sutinkate su žemiau išdėstytomis sąlygomis.</p>

        <h2>Informacijos pobūdis</h2>
        <p>Svetainėje pateikiama informacija apie teikiamas medžių priežiūros ir aukštuminių darbų paslaugas yra informacinio pobūdžio. Nurodyti įkainiai yra <strong>orientaciniai</strong> — galutinė kaina nustatoma įvertinus konkretų darbą vietoje arba pagal pateiktas nuotraukas.</p>

        <h2>Užklausos ir susitarimai</h2>
        <p>Užpildžius užklausos formą ar susisiekus telefonu, su jumis susisiekiame dėl paslaugos. Užklausos pateikimas neįpareigoja nei kliento, nei {site.pavadinimas} sudaryti sutartį — konkretūs darbai ir kaina suderinami atskirai.</p>

        <h2>Paslaugų atlikimas</h2>
        <p>Darbus atliekame laikydamiesi saugos reikalavimų ir geros praktikos. Tam tikrais atvejais (pvz. saugotinų medžių) gali prireikti savivaldybės leidimo — atsakomybė už reikiamus leidimus aptariama prieš pradedant darbus.</p>

        <h2>Intelektinė nuosavybė</h2>
        <p>Svetainės turinys, nuotraukos ir tekstai priklauso {site.pavadinimas}. Jų naudoti be sutikimo negalima.</p>

        <h2>Kontaktai</h2>
        <p>{site.pavadinimas}, {site.savininkas}<br />Tel.: <a href={site.telefonasHref}>{site.telefonas}</a><br />El. paštas: <a href={`mailto:${site.elPastas}`}>{site.elPastas}</a></p>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCall />
  <InquiryModal />
</BaseLayout>

<style>
  .legal { max-width: 760px; }
  .prose h2 { font-size: clamp(1.4rem, 2.2vw, 1.8rem); color: var(--color-forest); margin: var(--space-6) 0 var(--space-3); text-transform: uppercase; }
  .prose p { margin-bottom: var(--space-4); line-height: 1.8; }
  .prose a { color: var(--color-rust); font-weight: 600; }
  .prose strong { color: var(--color-forest); }
</style>
