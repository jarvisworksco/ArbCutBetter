---
import '../styles/global.css';
import { site } from '@data/site.js';
import { localBusiness } from '@data/jsonld.js';

const { title, description, ogImage, noindex = false, schemas } = Astro.props;
const pageTitle = title || site.metaTitle;
const desc = description || site.metaDescription;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImg = new URL(ogImage || site.ogImage, site.url).href;

/* JSON-LD: puslapis gali perduoti savo schemas; numatyta — LocalBusiness (NAP+
   reitingas+paslaugos). GEO §8: kiekvienas puslapis aiškiai apibrėžia KAS/KĄ/KUR. */
const schemaList = schemas && schemas.length ? schemas : [localBusiness()];
---
<!doctype html>
<html lang="lt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:site_name" content="ArbCut" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="lt_LT" />
    <meta property="og:image" content={ogImg} />
    <meta property="og:image:alt" content="ArbCut — medžių priežiūra ir aukštuminiai darbai" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImg} />

    <meta name="theme-color" content="#15402B" />
    <meta name="geo.region" content="LT" />
    <meta name="geo.placename" content="Kaunas, Lietuva" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    {schemaList.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Pereiti prie turinio</a>
    <slot />
    <script src="../scripts/site.js"></script>
  </body>
</html>
